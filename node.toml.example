# =============================================================================
# node.toml — configuration du node Toolbox (exemple complet documenté)
# =============================================================================
# Copiez ce fichier en `node.toml` à côté du binaire et ajustez.
# TOUT est optionnel : un node.toml absent ou vide démarre sur ces défauts.

# Nom du node sur le réseau (page fleet, mDNS en phase 2). Défaut : hostname.
#name = "vp-jardin"

[resolution]
# "auto" = résolution native détectée ; ou fixe :
mode = "fixed"
width = 1920
height = 1080

[modules]
# NB : ces valeurs sont les défauts du PREMIER démarrage. Ensuite, l'onglet
# « Fonctions » de l'UI web permet d'activer/désactiver chaque fonction à
# chaud (réellement arrêtée = zéro ressource) ; les bascules sont mémorisées
# dans fonctions.json et priment sur cette section. Seul `http` reste
# uniquement pilotée ici.
player = true      # lecture : GStreamer si le binaire l'embarque (feature `gstreamer`
                   # + runtime installé, voir deploy/README.md), sinon backend simulé
http = true        # web UI + API REST/WebSocket
osc = true         # contrôle OSC (Chataigne…)
midi = false       # contrôle MIDI (bindings ci-dessous)
sequencer = false  # phase 3
sync = false       # phase 2 (multi-device)
ndi = false        # jamais dans le core (plugin optionnel)

[ports]
bind = "0.0.0.0"   # "127.0.0.1" pour restreindre à la machine locale
http = 8080        # web UI : http://<ip>:8080/
osc = 9000         # UDP
oscquery = 8081    # auto-découverte des paramètres OSC (Chataigne : hôte + ce port)

[paths]
# Relatifs au dossier de travail → la version portable tient dans un dossier.
media = "media"
presets = "presets"       # les presets de mapping seul vont dans presets/mapping/
shaders = "shaders"
logs = "logs"             # journal quotidien sur disque (toolbox.log.AAAA-MM-JJ, 14 jours gardés)

[output]
# Fenêtre de sortie : mires de test et vidéo déformées en direct par le
# mapping. Sans mire ni lecture, la sortie est noire. F11 : plein écran,
# Échap : le quitte. NB : l'écran et le plein écran choisis dans l'UI web
# sont persistés dans sortie.json et priment sur ces valeurs au démarrage.
enabled = true
monitor = 0        # index de l'écran cible ; la liste détectée est dans les logs
fullscreen = false # true = plein écran sans bordure sur l'écran cible
gpu = true         # rendu par la carte graphique (repli CPU automatique en cas d'échec)
# Sortie SANS bureau (Raspberry Pi OS Lite, console) : mode = "kms" remplace
# la fenêtre par le plein écran DRM/KMS (binaire compilé avec `gstreamer`).
# La résolution vient de [resolution] ; à valider sur Pi réel.
#mode = "kms"
#kms_fps = 30

[startup]
# Mode kiosque (P1.9) : au démarrage, charger un preset et lancer la lecture.
# Avec le service systemd (Restart=always), le node reprend son show seul
# après une coupure de courant.
#preset = "show"
#autoplay = true
# Passthrough : source chargée et jouée au démarrage (APRÈS le preset, elle
# prime). Une source live absente est reprise automatiquement toutes les 3 s
# — carte débranchée puis rebranchée = l'image revient seule.
#source = "capture://0"
# NB : le bouton « état de démarrage » de l'UI écrit demarrage.json, qui
# prime sur toute cette section.

[security]
# Mot de passe de l'interface web et de l'API (absent = pas de mot de passe,
# réseau local de confiance). Le navigateur demande les identifiants :
# n'importe quel nom + ce mot de passe. L'OSC (UDP) reste ouvert.
# Préférez un mot de passe sans accents (certains outils n'envoient pas l'UTF-8).
#password = "changez-moi"

[limits]
max_upload_mb = 2048   # taille max d'un média déposé via la web UI
log_buffer = 1000      # entrées gardées par la page de logs

[sync]
# Synchronisation multi-machines niveau 2 : les suiveurs se verrouillent sur
# la position du maître (à la frame près — mesuré < 2 ms en local). Les
# horloges des machines doivent être en NTP. Les suiveurs s'annoncent
# d'eux-mêmes : côté maître, le rôle suffit.
#role = "maitre"            # ou "suiveur" (défaut : "aucun")
#maitre = "10.0.0.2:9010"   # suiveurs uniquement : adresse du maître
#port = 9010                # port UDP de l'horloge
#tolerance_ms = 80          # au-delà : resync dur (seek) ; en deçà : vitesse ±3 %

[osc]
# Retour d'état : chaque changement (volume, coins, couleur…) est renvoyé en
# OSC à cette adresse — les curseurs de Chataigne suivent le node.
#feedback = "10.0.0.5:9001"

[rtsp]
# Sortie RTSP (binaire compilé avec la feature `gstreamer` uniquement) :
# la sortie composée — mapping, couleur, LUT, blackout — servie en
# rtsp://<ip-du-node>:8554/sortie (H.264 si disponible, MJPEG sinon).
# Pipeline partagé : plusieurs clients ne coûtent qu'un rendu.
# Pour un coup d'œil rapide sans configuration : http://<ip>:8080/flux.mjpg.
#enabled = true
#port = 8554
#largeur = 1280
#hauteur = 720
#fps = 25

[ndi]
# Sortie NDI : la sortie composée (mapping, couleur, LUT, blackout) devient
# une source NDI sur le réseau — visible dans OBS, vMix, les moniteurs NDI.
# Le SDK NDI n'est PAS embarqué : installer le runtime NDI (gratuit) ou le
# SDK, la bibliothèque est chargée automatiquement au lancement.
# Raspberry Pi : copier libndi.so.6 (du SDK Linux, dossier lib/aarch64-...)
# dans /usr/local/lib.
#sortie = true
#nom = "Scène jardin"        # absent : « <nom du node> (Lanterne) »
#largeur = 1280
#hauteur = 720
#fps = 25
#bibliotheque = "C:/chemin/vers/Processing.NDI.Lib.x64.dll"  # si emplacement inhabituel

[telemetrie]
# Envoi des rapports de crash — STRICTEMENT opt-in : sans URL (défaut), rien
# ne sort jamais de la machine. Avec une URL : au démarrage qui suit un
# crash, le rapport (logs/crash.txt — panic, version, nom du node, aucune
# donnée personnelle) est envoyé en POST puis supprimé. crash.txt est écrit
# dans tous les cas : il sert d'abord au diagnostic local.
#url = "https://exemple.fr/rapports-toolbox"

[midi]
# Sous-chaîne du nom du port MIDI à ouvrir (absent = premier port trouvé).
#port = "APC"

# Bindings : note → commande fixe, CC → paramètre continu ou commande.
# Le vocabulaire `command` est EXACTEMENT celui de l'API JSON (voir README).

#[[midi.bindings]]
#note = 60                            # C4
#command = { cmd = "play" }

#[[midi.bindings]]
#note = 61
#command = { cmd = "stop" }

#[[midi.bindings]]
#cc = 7                               # fader volume
#scale = "volume"                     # 0..127 → 0..1

#[[midi.bindings]]
#cc = 1
#scale = "brightness"                 # 0..127 → 0..2

#[[midi.bindings]]
#note = 62
#channel = 10                         # canal précis (1..16)
#command = { cmd = "preset_load", name = "scene_01" }
